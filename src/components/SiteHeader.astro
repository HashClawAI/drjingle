---
import Avatar from '@/components/mirror/Avatar.astro';
import type { Locale, NavKey } from '@/lib/i18n';
import { t, localePath, localeSwitchPath } from '@/lib/i18n';

interface Props {
  locale: Locale;
  navCurrent?: NavKey;
  pathname: string;
}

const { locale, navCurrent = 'home', pathname } = Astro.props;
const tr = t(locale);
const switchHref = localeSwitchPath(locale, pathname);

const navItems: { key: NavKey; href: string; icon: string }[] = [
  { key: 'home', href: localePath(locale, '/'), icon: 'home' },
  { key: 'events', href: localePath(locale, '/category/events'), icon: 'events' },
  { key: 'insights', href: localePath(locale, '/category/insights'), icon: 'insights' },
  { key: 'research', href: localePath(locale, '/category/research'), icon: 'papers' },
  { key: 'ecosystem', href: localePath(locale, '/category/ecosystem'), icon: 'ecosystem' },
];
---

<header class="dj-header dj-header-linkedin">
  <div class="dj-shell dj-header-row">
    <a href={localePath(locale, '/')} class="dj-brand" aria-label={tr.siteName}>
      <Avatar size="brand" withRing={false} />
      <span class="dj-brand-text">
        <strong>Dr.Jingle<sup class="dj-mark">™</sup></strong>
        {locale !== 'en' && <em>{tr.brand.cnName}</em>}
      </span>
    </a>

    <nav class="dj-nav dj-nav-linkedin" aria-label={tr.nav.primary}>
      {navItems.map(({ key, href, icon }) => (
        <a href={href} class:list={['dj-nav-item', navCurrent === key && 'is-active']}>
          <span class="dj-nav-icon" aria-hidden="true">
            {icon === 'home' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M4 10.5 12 4l8 6.5V20a1 1 0 0 1-1 1h-5v-6H10v6H5a1 1 0 0 1-1-1v-9.5z"/></svg>
            )}
            {icon === 'events' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="5" width="18" height="16" rx="2"/><path d="M8 3v4M16 3v4M3 11h18"/></svg>
            )}
            {icon === 'insights' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M9 18h6M10 22h4M12 2a7 7 0 0 1 4 12.7V17H8v-2.3A7 7 0 0 1 12 2z"/></svg>
            )}
            {icon === 'ecosystem' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/></svg>
            )}
            {icon === 'papers' && (
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M8 4h8a2 2 0 0 1 2 2v14l-6-3-6 3V6a2 2 0 0 1 2-2z"/></svg>
            )}
          </span>
          <span class="dj-nav-label">{tr.nav[key]}</span>
        </a>
      ))}
    </nav>

    <div class="dj-header-actions">
      <form method="get" action={localePath(locale, '/')} class="dj-search" role="search">
        <span aria-hidden="true">⌘</span>
        <input type="search" name="search" placeholder={tr.search.placeholder} aria-label={tr.search.aria} />
      </form>
      <a href={switchHref} class="dj-locale-switch" aria-label={tr.localeSwitch.aria}>
        {locale === 'en' ? tr.localeSwitch.toZh : tr.localeSwitch.toEn}
      </a>
      <a href="https://x.com/drjingle" class="dj-link-out" target="_blank" rel="noopener noreferrer">@drjingle</a>
      <a href="https://github.com/HashClawAI/drjingle" class="dj-link-out dj-link-out-soft" target="_blank" rel="noopener noreferrer">GH</a>
      <a href="https://t.me/Y2049" class="dj-link-out dj-link-out-soft" target="_blank" rel="noopener noreferrer">TG</a>
    </div>
  </div>
</header>
