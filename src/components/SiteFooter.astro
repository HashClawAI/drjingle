---
import type { Locale } from '@/lib/i18n';
import { t } from '@/lib/i18n';

interface Props {
  locale: Locale;
  year: number;
}

const { locale, year } = Astro.props;
const tr = t(locale);
---

<footer class="dj-footer">
  <div class="dj-shell">
    <div class="dj-footer-grid">
      <div>
        <div class="dj-footer-brand">{tr.footer.brand}</div>
        <p class="dj-footer-desc">{tr.footer.desc}</p>
      </div>
      <div class="dj-footer-links">
        <div class="dj-footer-linkset" aria-label="Footer links">
          <a href="https://github.com/HashClawAI/drjingle" target="_blank" rel="noopener noreferrer">GitHub</a>
          <a href="https://t.me/Y2049" target="_blank" rel="noopener noreferrer">TG</a>
          <a href="https://paragraph.com/fahayek.eth" target="_blank" rel="noopener noreferrer">Paragraph</a>
          <a href="/llms.txt">llms</a>
          <a href="/sitemap-index.xml">Sitemap</a>
        </div>
        <a href="https://hashclaw.ai" class="dj-hashclaw-mark" target="_blank" rel="noopener noreferrer" aria-label="HashClaw.ai">
          <img src="/themes/drjingle-mirror/hashclaw-logo.jpeg" alt="HashClaw" loading="lazy" decoding="async" />
          <span>hashclaw.ai</span>
        </a>
      </div>
    </div>
    <div class="dj-footer-copy">{tr.footer.copy(year)}</div>
  </div>
</footer>
