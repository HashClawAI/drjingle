---
import type { Locale } from '@/lib/i18n';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<div class="dj-titles">
  {
    locale === 'en' && (
      <p class="dj-titles-en" lang="en">
        Deputy Director,
        <span class="dj-titles-affiliation">
          <a class="dj-title-link dj-title-link-cste" href="https://www.cste.org.cn/" target="_blank" rel="noopener noreferrer" title="cste.org.cn">Chinese Society of Technology Economics</a>
          <a class="dj-title-link dj-title-link-csteac" href="https://csteac.org/" target="_blank" rel="noopener noreferrer" title="csteac.org">North America Office</a>
        </span>
        · Lecturer,
        <a class="dj-title-link dj-title-link-polyu" href="https://www.polyu.edu.hk/" target="_blank" rel="noopener noreferrer" title="polyu.edu.hk">The Hong Kong Polytechnic University</a>
        · DBA
      </p>
    )
  }
  {
    locale === 'zh' && (
      <p class="dj-titles-zh" lang="zh-Hans">
        <span class="dj-titles-affiliation">
          <a class="dj-title-link dj-title-link-cste" href="https://www.cste.org.cn/" target="_blank" rel="noopener noreferrer" title="cste.org.cn">中国技术经济学会</a><a class="dj-title-link dj-title-link-csteac" href="https://csteac.org/" target="_blank" rel="noopener noreferrer" title="csteac.org">北美代表处</a><span class="dj-titles-suffix">副主任</span>
        </span>
        · <a class="dj-title-link dj-title-link-polyu" href="https://www.polyu.edu.hk/" target="_blank" rel="noopener noreferrer" title="polyu.edu.hk">香港理工大学</a><span class="dj-titles-suffix">讲师</span> · 工商管理博士
      </p>
    )
  }
</div>
