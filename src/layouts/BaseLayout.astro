---
import SiteHeader from '@/components/SiteHeader.astro';
import SiteFooter from '@/components/SiteFooter.astro';
import type { Locale } from '@/lib/i18n';
import { t } from '@/lib/i18n';

interface Props {
  locale: Locale;
  title: string;
  description: string;
  navCurrent?: 'home' | 'events' | 'insights' | 'research' | 'ecosystem';
}

const { locale, title, description, navCurrent = 'home' } = Astro.props;
const tr = t(locale);
const siteTitle = `${title} · ${tr.siteName}`;
const siteOrigin = Astro.site?.href ?? 'https://drjingle.com';
const canonicalUrl = new URL(Astro.url.pathname, siteOrigin).href;
const year = new Date().getFullYear();
---

<!doctype html>
<html lang={locale === 'zh' ? 'zh-Hans' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="keywords" content={tr.siteKeywords} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={siteTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL('/themes/drjingle-mirror/avatar-real-crop.jpg', siteOrigin).href} />
    <link rel="alternate" type="text/plain" href="/llms.txt" title="LLMs index" />
    <link rel="icon" href="/themes/drjingle-mirror/drjingle-logo-icon.png?v=6" type="image/png" />
    <link rel="stylesheet" href="/themes/drjingle-mirror/theme.css?v=43" />
    <title>{siteTitle}</title>
  </head>
  <body class="dj-body">
    <div class="dj-cosmos-bg" aria-hidden="true">
      <canvas id="dj-cosmos" class="dj-cosmos-canvas"></canvas>
      <div class="dj-aurora dj-aurora-a"></div>
      <div class="dj-aurora dj-aurora-b"></div>
      <div class="dj-grid-plane"></div>
      <div class="dj-orbital dj-orbital-a"></div>
      <div class="dj-orbital dj-orbital-b"></div>
    </div>
    <div class="dj-grain" aria-hidden="true"></div>
    <div id="dj-read-progress" class="dj-read-progress" role="presentation"></div>

    <SiteHeader locale={locale} navCurrent={navCurrent} pathname={Astro.url.pathname} />
    <main class="dj-main">
      <slot />
    </main>
    <SiteFooter locale={locale} year={year} />

    <script src="/themes/drjingle-mirror/theme.js?v=24" defer></script>
  </body>
</html>
