---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticleCard from '@/components/ArticleCard.astro';
import type { Locale } from '@/lib/i18n';
import { t } from '@/lib/i18n';
import { formatDate, getPublishedArticles } from '@/lib/articles';

export async function getStaticPaths() {
  const articles = await getCollection('articles', ({ data }) => !data.draft && data.locale === 'en');
  return articles.map((entry) => ({ params: { slug: entry.slug }, props: { entry } }));
}

const locale: Locale = 'en';
const { entry } = Astro.props;
const tr = t(locale);
const { Content } = await render(entry);
const all = await getPublishedArticles(locale);
const related = all.filter((a) => a.slug !== entry.slug && a.data.category === entry.data.category).slice(0, 3);
---

<BaseLayout
  locale={locale}
  title={entry.data.title}
  description={entry.data.description ?? entry.data.title}
  navCurrent={entry.data.category === 'research' ? 'research' : entry.data.category === 'events' ? 'events' : 'insights'}
>
  <article class="dj-article">
    <p class="dj-article-kicker">{tr.article.overline}</p>
    <h1>{entry.data.title}</h1>
    <time datetime={entry.data.pubDate.toISOString()}>{formatDate(entry.data.pubDate, locale)}</time>
    <div class="dj-prose">
      <Content />
    </div>
  </article>

  {related.length > 0 && (
    <section class="dj-related">
      <h2>{tr.article.related}</h2>
      <div class="dj-card-grid">
        {related.map((r) => (
          <ArticleCard entry={r} locale={locale} />
        ))}
      </div>
    </section>
  )}
</BaseLayout>

<style>
  .dj-article {
    max-width: var(--dj-read);
    margin: 0 auto;
  }
  .dj-article-kicker {
    font-size: 0.75rem;
    color: var(--dj-cyan);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }
  .dj-article h1 {
    font-size: clamp(1.65rem, 4vw, 2.35rem);
    line-height: 1.2;
    margin: 0.5rem 0;
  }
  .dj-article time {
    display: block;
    color: var(--dj-text-muted);
    font-size: 0.82rem;
    margin-bottom: 1.5rem;
  }
  .dj-related {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--dj-line);
  }
  .dj-prose :global(h2) {
    margin-top: 2rem;
    font-size: 1.25rem;
  }
  .dj-prose :global(p),
  .dj-prose :global(li) {
    color: var(--dj-text-soft);
    line-height: 1.75;
  }
  .dj-prose :global(a) {
    color: var(--dj-cyan);
    text-decoration: underline;
  }
  .dj-prose :global(img) {
    max-width: 100%;
    border-radius: var(--dj-radius);
  }
</style>
