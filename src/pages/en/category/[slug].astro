---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategoryPage from '@/components/mirror/CategoryPage.astro';
import type { Locale, NavKey } from '@/lib/i18n';
import { t } from '@/lib/i18n';
import { getArticlesByCategory } from '@/lib/articles';

export function getStaticPaths() {
  return ['insights', 'research', 'events', 'ecosystem'].map((slug) => ({ params: { slug } }));
}

const locale: Locale = 'en';
const { slug } = Astro.params;
const valid = ['insights', 'research', 'events', 'ecosystem'] as const;
if (!slug || !valid.includes(slug as (typeof valid)[number])) {
  return Astro.redirect('/en/');
}

const cat = slug as (typeof valid)[number];
const tr = t(locale);
const items = cat === 'ecosystem' ? [] : await getArticlesByCategory(cat, locale);

const navCurrent: NavKey = cat;
const pageTitle = tr.nav[cat];
const pageDesc =
  cat === 'insights'
    ? tr.category.insightsDesc
    : cat === 'research'
      ? tr.category.researchDesc
      : cat === 'events'
        ? tr.category.eventsDesc
        : tr.category.ecosystemDesc;
---

<BaseLayout locale={locale} title={pageTitle} description={pageDesc} navCurrent={navCurrent}>
  <CategoryPage locale={locale} slug={cat} items={items} />
</BaseLayout>
