---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SeriesPage from '@/components/mirror/SeriesPage.astro';
import type { Locale } from '@/lib/i18n';
import { getPublishedArticles } from '@/lib/articles';
import seriesData from '@/data/series.json';

export function getStaticPaths() {
  return Object.keys(seriesData).map((slug) => ({ params: { slug } }));
}

const locale: Locale = 'zh';
const { slug } = Astro.params;
const meta = seriesData[slug as keyof typeof seriesData];
if (!meta) return Astro.redirect('/');

const title = meta.title_zh;
const desc = meta.desc_zh;
const all = await getPublishedArticles(locale);
const items = meta.articles.map((s) => all.find((a) => a.slug === s)).filter((a): a is NonNullable<typeof a> => Boolean(a));
---

<BaseLayout locale={locale} title={title} description={desc} navCurrent="insights">
  <SeriesPage locale={locale} title={title} desc={desc} items={items} />
</BaseLayout>
