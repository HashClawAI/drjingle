---
import { render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import ArticlePage from '@/components/mirror/ArticlePage.astro';
import type { Locale } from '@/lib/i18n';
import { getPublishedArticles, articleImage, articleSlug } from '@/lib/articles';

export async function getStaticPaths() {
  const { getCollection } = await import('astro:content');
  const articles = await getCollection('articles', ({ data }) => !data.draft && data.locale === 'en');
  return articles.map((entry) => ({ params: { slug: articleSlug(entry) }, props: { entry } }));
}

const locale: Locale = 'en';
const { entry } = Astro.props;
const { Content } = await render(entry);
const all = await getPublishedArticles(locale);
const alternateArticles = await getPublishedArticles('zh');
const slug = articleSlug(entry);
const alternatePath = alternateArticles.some((article) => articleSlug(article) === slug) ? `/zh/article/${slug}/` : null;
const related = all
  .filter((a) => articleSlug(a) !== slug && a.data.category === entry.data.category)
  .slice(0, 5);
const navCurrent =
  entry.data.category === 'research' ? 'research' : entry.data.category === 'events' ? 'events' : 'insights';
const siteOrigin = Astro.site?.href ?? 'https://drjingle.com';
const canonicalUrl = new URL(`/article/${slug}/`, siteOrigin).href;
const image = articleImage(entry);
const articleSchema = [
  {
    '@type': 'BlogPosting',
    '@id': `${canonicalUrl}#article`,
    headline: entry.data.title,
    description: entry.data.description ?? entry.data.title,
    datePublished: entry.data.pubDate.toISOString(),
    dateModified: (entry.data.updatedDate ?? entry.data.pubDate).toISOString(),
    inLanguage: 'en',
    mainEntityOfPage: canonicalUrl,
    image: new URL(image ?? '/themes/drjingle-mirror/avatar-real-crop.jpg', siteOrigin).href,
    author: { '@id': `${siteOrigin}#person` },
    publisher: { '@id': `${siteOrigin}#person` },
    keywords: entry.data.tags?.join(', '),
  },
  {
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: siteOrigin },
      { '@type': 'ListItem', position: 2, name: entry.data.category, item: new URL(`/category/${entry.data.category}`, siteOrigin).href },
      { '@type': 'ListItem', position: 3, name: entry.data.title, item: canonicalUrl },
    ],
  },
];
---

<BaseLayout
  locale={locale}
  title={entry.data.title}
  description={entry.data.description ?? entry.data.title}
  navCurrent={navCurrent}
  pageType="article"
  image={image}
  publishedTime={entry.data.pubDate.toISOString()}
  modifiedTime={(entry.data.updatedDate ?? entry.data.pubDate).toISOString()}
  tags={entry.data.tags ?? []}
  structuredData={articleSchema}
  alternatePath={alternatePath}
>
  <ArticlePage locale={locale} entry={entry} Content={Content} related={related} />
</BaseLayout>
