---
import BaseLayout from '@/layouts/BaseLayout.astro';
import CategoryPage from '@/components/mirror/CategoryPage.astro';
import type { Locale, NavKey } from '@/lib/i18n';
import { t } from '@/lib/i18n';
import { loadCategoryArticles, type CategorySlug } from '@/lib/categoryPage';

export function getStaticPaths() {
  return ['insights', 'research', 'events', 'ecosystem'].map((slug) => ({ params: { slug } }));
}

const locale: Locale = 'zh';
const { slug } = Astro.params;
const valid = ['insights', 'research', 'events', 'ecosystem'] as const;
if (!slug || !valid.includes(slug as (typeof valid)[number])) {
  return Astro.redirect('/zh/');
}

const cat = slug as CategorySlug;
const tr = t(locale);
const { pageData } =
  cat === 'ecosystem'
    ? { pageData: { items: [], totalItems: 0, currentPage: 1, totalPages: 1 } }
    : await loadCategoryArticles(cat, locale, 1);
const items = pageData.items;

const navCurrent: NavKey = cat;

const pageTitle = tr.nav[cat];
const pageDesc =
  cat === 'insights'
    ? tr.category.insightsDesc
    : cat === 'research'
      ? tr.category.researchDesc
      : cat === 'events'
        ? tr.category.eventsDesc
        : tr.category.ecosystemDesc;
---

<BaseLayout locale={locale} title={pageTitle} description={pageDesc} navCurrent={navCurrent}>
  <CategoryPage
    locale={locale}
    slug={cat}
    items={items}
    totalItems={pageData.totalItems}
    currentPage={pageData.currentPage}
    totalPages={pageData.totalPages}
  />
</BaseLayout>
